# --- CONFIGURAÇÕES GERAIS ---
DEBUG_MODE=True

# --- OPENWEATHER API (CLIMA) ---
OPENWEATHER_API_KEY=sua_chave_aqui
LAT=-23.5505
LONG=-46.6333

# --- SPOTIFY API (MÚSICA) ---
# Obtenha o ID e Secret em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui
# Use o script get_refresh_token.py para gerar este:
SPOTIFY_REFRESH_TOKEN=seu_refresh_token_aqui

# --- PRINTER (KLIPPER / K1 MAX) ---
# IP da sua impressora (ex: http://192.168.1.50)
PRINTER_URL=http://octopi.local
PRINTER_API_KEY=opcional_no_moonraker
PRINTER_TYPE=moonraker
